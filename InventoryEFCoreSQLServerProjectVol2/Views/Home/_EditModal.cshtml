<!-- Edit Product Modal -->
<div class="modal fade" id="editProductModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Редактиране на продукт</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="editProductForm">
                    <input type="hidden" id="editProductId" />
                    <div class="mb-3">
                        <label class="form-label">Име на продукта *</label>
                        <input type="text" id="editProductName" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Количество *</label>
                        <input type="number" id="editProductQuantity" class="form-control" required min="0">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Цена (€) *</label>
                        <input type="number" id="editProductPrice" class="form-control" required min="0" step="0.01">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Доставчик *</label>
                        <input type="text" id="editProductSupplier" class="form-control" required>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отказ</button>
                <button type="button" class="btn btn-primary" onclick="updateProduct()">Запази</button>
            </div>
        </div>
    </div>
</div>
