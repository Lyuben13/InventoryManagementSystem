@{
    ViewData["Title"] = "Поверителност на данни";
}

<div class="row">
    <div class="col-md-8">
        <h1 class="h2 fw-bold mb-4">Поверителност на данни</h1>
        
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <h5 class="card-title">Събиране на данни</h5>
                <p class="text-muted">
                    Нашата инвентарна система събира само необходимите данни за управление на складови наличности. 
                    Не събираме лична информация без вашето изрично съгласие.
                </p>
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <h5 class="card-title">Използване на данни</h5>
                <p class="text-muted">
                    Данните се използват единствено за:
                </p>
                <ul class="text-muted">
                    <li>Управление на инвентара</li>
                    <li>Генериране на отчети</li>
                    <li>Оптимизация на складовите наличности</li>
                </ul>
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <h5 class="card-title">Сигурност</h5>
                <p class="text-muted">
                    Всички данни се съхраняват сигурно с помощта на модерни технологии за криптиране 
                    и защита срещу неоторизиран достъп.
                </p>
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <h5 class="card-title">GDPR съответствие</h5>
                <p class="text-muted">
                    Нашата система е съвместима с Общия регламент за защита на данните (GDPR) 
                    и предоставя пълен контрол върху вашите данни.
                </p>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white">
                <h6 class="mb-0">Бързи връзки</h6>
            </div>
            <div class="card-body">
                <div class="list-group list-group-flush">
                    <a href="/" class="list-group-item list-group-item-action">
                        <i class="bi bi-house me-2"></i> Начало
                    </a>
                    <a href="/swagger" target="_blank" class="list-group-item list-group-item-action">
                        <i class="bi bi-code me-2"></i> API Документация
                    </a>
                    <a href="/health" class="list-group-item list-group-item-action">
                        <i class="bi bi-heartbeat me-2"></i> Системен статус
                    </a>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm mt-4">
            <div class="card-header bg-white">
                <h6 class="mb-0">Технологии</h6>
            </div>
            <div class="card-body">
                <div class="d-flex flex-wrap gap-2">
                    <span class="badge bg-primary">.NET 8</span>
                    <span class="badge bg-success">EF Core</span>
                    <span class="badge bg-info">SQL Server</span>
                    <span class="badge bg-warning">Bootstrap</span>
                </div>
            </div>
        </div>
    </div>
</div>
